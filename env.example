# AI Model API Keys
NEXT_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here
NEXT_PUBLIC_CLAUDE_API_KEY=your_claude_api_key_here

# Backend Service URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase Session Storage Integration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Firebase Progressive Web App Offline-Sync Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Google Maps API Integration (PHC Locator / Distance matrix)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# ─── Backend Authentication & SMS OTP Settings ────────────────────────
# JWT Secret for signing session tokens
JWT_SECRET=aarogyasetu_secret_key_12345!@#

# Optional: Indian SMS Gateway Fast2SMS Credentials (real OTP delivery)
FAST2SMS_API_KEY=your_fast2sms_api_key_here

# Optional: Global SMS Gateway Twilio Credentials (fallback real OTP delivery)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_token_here
TWILIO_FROM_NUMBER=your_twilio_from_phone_number_here
